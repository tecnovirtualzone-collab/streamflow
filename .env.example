# StreamFlow v5.0 - Node.js Edition
# Configuración 100% vía variables de entorno

# Server
PORT=5000
NODE_ENV=production
TZ=America/Bogota

# Database
DATA_DIR=/data

# Security
JWT_SECRET=cambiar_por_un_secreto_seguro_minimo_32_caracteres
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10
INITIAL_ADMIN_PASSWORD=***

# Streaming
STREAM_MAX_CONCURRENT=3
STREAM_INACTIVITY_TIMEOUT_MS=120000
